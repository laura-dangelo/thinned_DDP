namesave = paste0("01_Simulation_study/results/est_cl_pool", n_groups[i], "groups_", sum(n_groups[i]/2*ssg*j), "n_", repl,".RDS")
saveRDS(cl_point_est_pool, file = namesave)
rand_pool = 0
