nameopen = paste0("../04_Simulation_commonatoms/Results/time_pool", n_groups[i], "groups_", sum(n_groups[i]/2*ssg*j), "n_", repl,".Rdata")
time_pool = readRDS(nameopen)
newdata = c("pool", n_groups[i], sum(n_groups[i]/2*ssg*j), time_pool)
